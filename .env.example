APP_NAME=Markaz
APP_ENV=production
APP_KEY=<ضع هنا المفتاح الناتج من: php artisan key:generate --show>
APP_DEBUG=false
APP_URL=https://<your-app-name>.onrender.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ── بيانات حساب الأدمن ──────────────────────────────
ADMIN_SEED_NAME="مدير النظام"
ADMIN_SEED_EMAIL=<ضع بريد حقيقي>
ADMIN_SEED_PASSWORD=<ضع كلمة مرور قوية وغيّرها فورًا بعد أول تسجيل دخول>

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── قاعدة البيانات: MySQL خارجي (مثل Aiven / PlanetScale / FreeSQLDatabase) ──
# لا تستخدم sqlite في الإنتاج على Render — نظام الملفات مؤقت ويُمحى مع كل نشر
DB_CONNECTION=mysql
DB_HOST=<مضيف قاعدة البيانات>
DB_PORT=3306
DB_DATABASE=<اسم القاعدة>
DB_USERNAME=<اسم المستخدم>
DB_PASSWORD=<كلمة المرور>

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

TRACKING_START_TIME="14:00"
TRACKING_END_TIME="17:00"

VITE_APP_NAME="${APP_NAME}"
