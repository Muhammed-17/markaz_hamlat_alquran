    {{-- ✅ مطلوب لإخفاء العناصر قبل تحميل Alpine --}}
    <style>
        [x-cloak] {
            display: none !important;
        }
    </style>

    <script>
        window.__studentFormPageConfig = {
            initialTab: {
                {
                    $initialTab
                }
            },
            isEdit: @json($isEdit),
            formData: @json($formDataDefaults),
        };

        function studentFormPage() {
            const config = window.__studentFormPageConfig || {};

            return {
                activeTab: config.initialTab || 1,
                isEdit: config.isEdit || false,
                isRecording: null,
                stepErrors: {},
                stepTitles: [
                    'بيانات المشرف', 'البيانات الأساسية', 'البيانات الدراسية',
                    'بيانات الرعاية', 'تقييم التلاوة', 'مستوى البناء',
                    'مستوى الإتقان', 'مستوى الإبداع', 'التوصيات والملاحظات'
                ],
                formData: config.formData || {},

                isStepVisible(step) {
                    if (step === 6) return this.formData.center_entry_level === 'construction';
                    if (step === 7) return this.formData.center_entry_level === 'itqan';
                    if (step === 8) return this.formData.center_entry_level === 'ibda';
                    return true;
                },

                validateCurrentStep() {
                    if (this.isEdit) return true;
                    const requiredFields = {
                        1: ['supervisor_id', 'join_date'],
                        2: ['applicant', 'name', 'gender', 'address', 'center', 'guardian_id'],
                        3: ['educational_stage', 'education_type', 'school_grade', 'previous_school'],
                        4: ['health_status', 'learning_difficulties', 'personal_traits', 'hobbies', 'student_exit_status'],
                        5: ['reading', 'center_entry_level'],
                        6: ['current_surah', 'study_system', 'group_name'],
                        7: ['previous_memorization_side', 'previous_khatamat_count', 'current_review_amount', 'desired_path'],
                        8: ['description', 'desired_narration_and_path'],
                    };
                    const fields = requiredFields[this.activeTab] || [];
                    const errors = {};
                    fields.forEach(field => {
                        const val = this.formData[field];
                        if (!val || (typeof val === 'string' && val.trim() === '')) {
                            errors[field] = true;
                        } else if (Array.isArray(val) && val.length === 0) {
                            errors[field] = true;
                        }
                    });
                    this.stepErrors = errors;
                    return Object.keys(errors).length === 0;
                },

                showSection(num) {
                    if (this.isEdit) {
                        if (num === 6) return this.formData.center_entry_level === 'construction';
                        if (num === 7) return this.formData.center_entry_level === 'itqan';
                        if (num === 8) return this.formData.center_entry_level === 'ibda';
                        return true;
                    }
                    return this.activeTab === num;
                },

                goToStep(step) {
                    if (this.isEdit || step < 1 || step > 9) return;

                    // منع الانتقال لـ tab مستوى لا ينتمي له الطالب
                    if (step === 6 && this.formData.center_entry_level !== 'construction') return;
                    if (step === 7 && this.formData.center_entry_level !== 'itqan') return;
                    if (step === 8 && this.formData.center_entry_level !== 'ibda') return;

                    this.activeTab = step;
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                },

                nextStep() {
                    if (this.isEdit) return;
                    if (!this.validateCurrentStep()) return;

                    // من Tab 5 — اذهب مباشرة للمستوى الصحيح
                    if (this.activeTab === 5) {
                        if (this.formData.center_entry_level === 'construction') this.activeTab = 6;
                        else if (this.formData.center_entry_level === 'itqan') this.activeTab = 7;
                        else if (this.formData.center_entry_level === 'ibda') this.activeTab = 8;
                        else this.activeTab = 9;
                    }
                    // من أي من tabs المستويات — اذهب مباشرة لـ Tab 9
                    else if (this.activeTab === 6 || this.activeTab === 7 || this.activeTab === 8) {
                        this.activeTab = 9;
                    } else if (this.activeTab < 9) {
                        this.activeTab++;
                    }

                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                    this.stepErrors = {};
                },

                prevStep() {
                    if (this.isEdit || this.activeTab <= 1) return;

                    // من Tab 9 — ارجع للمستوى الصحيح
                    if (this.activeTab === 9) {
                        if (this.formData.center_entry_level === 'construction') this.activeTab = 6;
                        else if (this.formData.center_entry_level === 'itqan') this.activeTab = 7;
                        else if (this.formData.center_entry_level === 'ibda') this.activeTab = 8;
                        else this.activeTab = 5;
                    }
                    // من أي من tabs المستويات — ارجع لـ Tab 5
                    else if (this.activeTab === 6 || this.activeTab === 7 || this.activeTab === 8) {
                        this.activeTab = 5;
                    } else {
                        this.activeTab--;
                    }

                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                    this.stepErrors = {};
                },

                hasError(field) {
                    return this.stepErrors[field] || false;
                },

                startDictation(field) {
                    if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
                        alert('المتصفح لا يدعم ميزة الإملاء الصوتي');
                        return;
                    }
                    if (this.isRecording === field) {
                        this.isRecording = null;
                        return;
                    }
                    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                    const recognition = new SpeechRecognition();
                    recognition.lang = 'ar-EG';
                    recognition.continuous = false;
                    recognition.interimResults = false;

                    this.isRecording = field;
                    recognition.onresult = (event) => {
                        const transcript = event.results[0][0].transcript;
                        this.formData[field] = this.formData[field] ?
                            this.formData[field] + ' ' + transcript :
                            transcript;
                    };
                    recognition.onend = () => {
                        this.isRecording = null;
                    };
                    recognition.onerror = () => {
                        this.isRecording = null;
                    };
                    recognition.start();
                },
            };
        }
    </script>

    <div x-data="studentFormPage()" class="space-y-8">
        <input type="hidden" name="active_tab" :value="activeTab" x-show="!isEdit">

        @if (! $isEdit)
